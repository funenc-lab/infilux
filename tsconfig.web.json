{
  "extends": "@electron-toolkit/tsconfig/tsconfig.web.json",
  "compilerOptions": {
    "composite": true,
    "declaration": true,
    "declarationMap": true,
    "outDir": "./out/types/web",
    "jsx": "react-jsx",
    "baseUrl": ".",
    "paths": {
      "@/*": ["src/renderer/*"],
      "@shared/*": ["src/shared/*"]
    }
  },
  "include": [
    "package.json",
    "src/preload/index.ts",
    "src/preload/sessionEventRouter.ts",
    "src/preload/types.ts",
    "src/renderer/**/*",
    "src/renderer/**/*.json",
    "src/shared/**/*"
  ]
}
